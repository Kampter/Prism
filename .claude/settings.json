{
  "permissions": {
    "allow": [
      "Bash:./scripts/*",
      "Bash:git *",
      "Bash:python *",
      "Bash:node *",
      "Bash:npm *",
      "Bash:yarn *",
      "Bash:pnpm *",
      "Bash:pytest *",
      "Bash:black *",
      "Bash:prettier *",
      "Bash:eslint *",
      "Bash:flake8 *",
      "Bash:mypy *",
      "Bash:tsc *",
      "Bash:shellcheck *",
      "Bash:shfmt *",
      "Bash:ruff *",
      "Bash:cat",
      "Bash:echo",
      "Bash:mkdir",
      "Bash:cp",
      "Bash:mv",
      "Bash:touch",
      "Bash:ls",
      "Bash:find",
      "Bash:grep",
      "Bash:head",
      "Bash:tail",
      "Bash:wc",
      "Bash:sort",
      "Bash:uniq",
      "Bash:jq",
      "Read:./**",
      "Edit:./**",
      "Write:./**"
    ],
    "deny": [
      "Write:**/.env*",
      "Write:**/package-lock.json",
      "Write:**/yarn.lock",
      "Write:**/pnpm-lock.yaml",
      "Write:**/.git/**",
      "Write:**/node_modules/**",
      "Write:**/.claude/settings.json",
      "Bash:rm -rf /**",
      "Bash:sudo *",
      "Bash:curl *|*sh*",
      "Bash:wget *|*sh*",
      "Bash:eval *",
      "Bash:exec *",
      "Bash:bash -c *",
      "Bash:sh -c *"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "command": ".claude/hooks/security-scan.sh"
      },
      {
        "matcher": "Edit|Write",
        "command": ".claude/hooks/format-code.sh"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "command": ".claude/hooks/run-tests.sh"
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "command": "echo '[Prism] Session started. Run ./scripts/validate.sh to verify harness.'"
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "command": "echo '[Prism] Session ended.'"
      }
    ]
  },
  "attribution": {
    "commit": "",
    "pullRequest": ""
  },
  "sandbox": {
    "enabled": true,
    "allowNetwork": true,
    "allowFilesystem": true,
    "readonlyPaths": [
      ".git/",
      "node_modules/"
    ]
  },
  "env": {
    "PRISM_ENV": "development",
    "PYTHONPATH": ".",
    "NODE_ENV": "development"
  }
}
